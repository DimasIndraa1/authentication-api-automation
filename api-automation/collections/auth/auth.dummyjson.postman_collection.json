  "item": [
    {
      "name": "Positive Flow",
      "item": [
        {
          "name": "/auth/login/positive",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// variables \r",
                  "const response = pm.response.json();\r",
                  "const accessToken_rs = response?.accessToken;\r",
                  "const refreshToken_rs = response?.refreshToken;\r",
                  "const id_rs = response?.id;\r",
                  "const username_rs = response?.username;\r",
                  "const email_rs = response?.email;\r",
                  "const firstName_rs = response?.firstName;\r",
                  "const lastName_rs = response?.lastName;\r",
                  "const gender_rs = response?.gender;\r",
                  "const image_rs = response?.image;\r",
                  "const nameRegex =  /^[a-zA-Z\\s'-]+$/;\r",
                  "// variables environments\r",
                  "const username = pm.environment.get(\"username\");\r",
                  "const password = pm.environment.get(\"password\");\r",
                  "const expiresInMins = pm.environment.get(\"expiresInMins\");\r",
                  "// Test\r",
                  "pm.test(\"01 | Status Code Valid yaitu 200\", () => {\r",
                  "    pm.expect(pm.response.code).to.eql(200);\r",
                  "});\r",
                  "pm.test(\"02 | Memiliki Field Lengkap response dan tidak kosong\", () => {\r",
                  "    pm.expect(response).to.not.be.null;\r",
                  "    pm.expect(response).to.include.all.keys(\"accessToken\", \"refreshToken\", \"id\", \"username\", \"email\", \"firstName\", \"lastName\", \"gender\", \"image\").and.to.not.be.empty;\r",
                  "});\r",
                  "pm.test(\"03 | Password tidak ada di response\", () => {\r",
                  "    pm.expect(response).to.not.have.property(\"password\")\r",
                  "});\r",
                  "pm.test(\"04 | AccessToken tidak kosong dan valid menggunakan format JWT\", () => {\r",
                  "    pm.expect(accessToken_rs).to.be.a(\"string\").and.to.not.be.empty;\r",
                  "    pm.expect(accessToken_rs.split(\".\").every(part => part.length > 0)).to.be.true;\r",
                  "});\r",
                  "pm.test(\"05 | RefreshToken tidak kosong dan valid menggunakan format JWT\", () => {\r",
                  "    pm.expect(refreshToken_rs).to.be.a(\"string\").and.not.empty;\r",
                  "    pm.expect(refreshToken_rs.split(\".\").every(part => part.length > 0)).to.be.true;\r",
                  "});\r",
                  "pm.test(\"06 | Id bernilai angka positif (bukan 0 atau negatif)\", () => {\r",
                  "    pm.expect(id_rs).to.be.a(\"number\").and.to.be.above(0);\r",
                  "});\r",
                  "pm.test(\"07 | ID adalah bilangan bulat (integer)\", () => {\r",
                  "    pm.expect(id_rs % 1).to.eql(0);\r",
                  "});\r",
                  "pm.test(\"08 | Username response sesuai dengan username request dan tidak ada spasi\", () => {\r",
                  "    pm.expect(username_rs).to.equal(username);\r",
                  "    pm.expect(username_rs).to.not.include(\" \");\r",
                  "});\r",
                  "pm.test(\"09 | Format pada email valid mengandung @ dan domain\", () => {\r",
                  "    pm.expect(email_rs).to.include(\"@\").and.to.match(/^[\\w-\\.]+@([\\w-]+\\.)+[\\w-]{2,4}$/);\r",
                  "});\r",
                  "pm.test(\"10 | FirstName dan lastName hanya berisi karakter alfabet (tanpa angka/simbol)\", () => {\r",
                  "    pm.expect(firstName_rs).to.be.a(\"string\").and.to.match(nameRegex);\r",
                  "    pm.expect(lastName_rs).to.be.a(\"string\").and.to.match(nameRegex);\r",
                  "});\r",
                  "pm.test(\"11 | FirstName & lastName tidak mengandung spasi di awal/akhir (trimmed)\", () => {\r",
                  "    pm.expect(firstName_rs).to.eql(firstName_rs.trim());\r",
                  "    pm.expect(lastName_rs).to.eql(lastName_rs.trim());\r",
                  "});\r",
                  "pm.test(\"12 | Field gender hanya berisi value male / female\", () => {\r",
                  "    pm.expect(gender_rs).to.be.oneOf([\"male\", \"female\"]);\r",
                  "});\r",
                  "pm.test(\"13 | Field image berupa URL valid dengan format (https://)\", () => {\r",
                  "    pm.expect(image_rs).to.match(/^https?:\\/\\/.+/);\r",
                  "});\r",
                  "pm.test(\"14 | Image URL dapat diakses\", () => {\r",
                  "    pm.sendRequest(image_rs, function (err, res) {\r",
                  "        pm.expect(err).to.be.null;\r",
                  "        pm.expect(res).to.have.property(\"code\", 200);\r",
                  "    });\r",
                  "});\r",
                  "pm.test(\"15 | Response time di bawah 3 detik\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n   \"username\": \"{{username}}\",\r\n   \"password\": \"{{password}}\",\r\n   \"expiresInMins\": {{expiresInMins}}\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Generated from cURL: curl -X POST https://dummyjson.com/auth/login \\\r\n     -H \"Content-Type: application/json\" \\\r\n     -d '{\r\n       \"username\": \"emilys\",\r\n       \"password\": \"emilyspass\",\r\n       \"expiresInMins\": 30\r\n     }'"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Negative Flow",
      "item": [
        {
          "name": "/auth/login/negative",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ================================================================\r",
                  "// NEGATIVE TEST CASE — LOGIN AUTH\r",
                  "// 1 Request Postman, 8 Scenario Parallel\r",
                  "// ================================================================\r",
                  "const BASE_URL = pm.environment.get(\"base_url\") + \"/auth/login\"\r",
                  "const HDR      = [{ key: \"Content-Type\", value: \"application/json\" }]\r",
                  "const env = {\r",
                  "    username: pm.environment.get(\"username\"),\r",
                  "    password: pm.environment.get(\"password\"),\r",
                  "    expires:  pm.environment.get(\"expiresInMins\")\r",
                  "}\r",
                  "// ── HELPER ──\r",
                  "function assertResponse(label, { expectedStatus, expectedField, category, type }, err, res) {\r",
                  "    if (err) {\r",
                  "        pm.test(`${label} ❌ Request gagal`, () => { throw err })\r",
                  "        return\r",
                  "    }\r",
                  "    const response = res.json()\r",
                  "    const message  = (response?.message ?? \"\").toLowerCase()\r",
                  "    const raw      = JSON.stringify(response).toLowerCase()\r",
                  "    pm.test(`${label} | N-01 Status respons ${expectedStatus}`, () => {\r",
                  "        pm.expect(res.code).to.eql(expectedStatus)\r",
                  "    })\r",
                  "    pm.test(`${label} | N-02 Response adalah JSON yang valid`, () => {\r",
                  "        pm.expect(res.headers.get(\"content-type\")).to.include(\"json\")\r",
                  "    })\r",
                  "    pm.test(`${label} | N-03 Response time < 10 detik`, () => {\r",
                  "        pm.expect(res.responseTime).to.be.below(10000)\r",
                  "    })\r",
                  "    if (type !== \"success\") {\r",
                  "        pm.test(`${label} | N-04 Terdapat pesan error di response`, () => {\r",
                  "            pm.expect(response?.message).to.be.a(\"string\").and.not.empty\r",
                  "        })\r",
                  "        pm.test(`${label} | N-05 Token tidak ada di response`, () => {\r",
                  "            pm.expect(raw).to.not.include('\"accesstoken\"')\r",
                  "            pm.expect(raw).to.not.include('\"refreshtoken\"')\r",
                  "        })\r",
                  "        pm.test(`${label} | N-06 Data tidak ada atau null di response`, () => {\r",
                  "            if (response.hasOwnProperty(\"data\")) {\r",
                  "                pm.expect(response.data).to.eql(null)\r",
                  "            } else {\r",
                  "                pm.expect(response.hasOwnProperty(\"data\")).to.eql(false)\r",
                  "            }\r",
                  "        })\r",
                  "    }\r",
                  "    pm.test(`${label} | N-07 Tidak mengekspos info sensitif`, () => {\r",
                  "        const sensitive = [\"stack\", \"exception\", \"sql\", \"db\"]\r",
                  "        sensitive.forEach(k => pm.expect(raw).to.not.include(k))\r",
                  "    })\r",
                  "    if (category === \"validation\" && expectedField) {\r",
                  "        pm.test(`${label} | N-09 Pesan error menyebutkan field \"${expectedField}\"`, () => {\r",
                  "            pm.expect(message).to.satisfy(msg =>\r",
                  "                msg.includes(expectedField) || msg.includes(\"required\") || msg.includes(\"wajib\")\r",
                  "            )\r",
                  "        })\r",
                  "    }\r",
                  "    if (category === \"auth\") {\r",
                  "        pm.test(`${label} | N-08 Pesan error generik (cegah user enumeration)`, () => {\r",
                  "            const genericCheck = [\r",
                  "                \"username tidak ditemukan\", \"user not found\", \"username tidak ada\",\r",
                  "                \"password salah\", \"wrong password\", \"invalid password\", \"tidak terdaftar\"\r",
                  "            ]\r",
                  "            genericCheck.forEach(k => pm.expect(message).to.not.include(k))\r",
                  "        })\r",
                  "    }\r",
                  "    if (type === \"success\") {\r",
                  "        pm.test(`${label} | N-10 accessToken === refreshToken`, () => {\r",
                  "            const accessToken  = response?.accessToken\r",
                  "            const refreshToken = response?.refreshToken\r",
                  "            pm.expect(accessToken).to.be.a(\"string\").and.not.empty\r",
                  "            pm.expect(refreshToken).to.be.a(\"string\").and.not.empty\r",
                  "            pm.expect(accessToken).to.eql(refreshToken)\r",
                  "        })\r",
                  "    }\r",
                  "}\r",
                  "// ── DAFTAR SKENARIO ──\r",
                  "const scenarios = [\r",
                  "    { name: \"VS-01 Empty Body\",       body: {},                                                status: 400, cat: \"validation\", field: null, type: \"error\" },\r",
                  "    { name: \"VS-02 Missing Password\", body: { username: env.username, expiresInMins: env.expires }, status: 400, cat: \"validation\", field: \"password\", type: \"error\" },\r",
                  "    { name: \"VS-03 Missing Username\", body: { password: env.password, expiresInMins: env.expires }, status: 400, cat: \"validation\", field: \"username\", type: \"error\" },\r",
                  "    { name: \"VS-04 Wrong Format\",     body: { username: \"emi lys\", password: \"emilyspass@@\", expiresInMins: env.expires }, status: 400, cat: \"validation\", field: null, type: \"error\" },\r",
                  "    { name: \"VS-05 Wrong Password\",   body: { username: env.username, password: \"password_salah_123\", expiresInMins: env.expires }, status: 400, cat: \"auth\", field: null, type: \"error\" },\r",
                  "    { name: \"VS-06 Unknown Username\", body: { username: \"user_tidak_terdaftar_xyz\", password: env.password, expiresInMins: env.expires }, status: 400, cat: \"validation\", field: null, type: \"error\" },\r",
                  "    { name: \"VS-07 ExpiresInMins 0\",  body: { username: env.username, password: env.password, expiresInMins: 0  }, status: 200, cat: \"validation\", field: null, type: \"success\" },\r",
                  "    { name: \"VS-08 ExpiresInMins -1\", body: { username: env.username, password: env.password, expiresInMins: -1 }, status: 500, cat: \"validation\", field: null, type: \"error\" }\r",
                  "]\r",
                  "// ── PARALLEL RUNNER ──\r",
                  "scenarios.forEach(s => {\r",
                  "    pm.sendRequest({\r",
                  "        url: BASE_URL, method: \"POST\", header: HDR,\r",
                  "        body: { mode: \"raw\", raw: JSON.stringify(s.body) }\r",
                  "    }, (err, res) => {\r",
                  "        assertResponse(s.name, {\r",
                  "            expectedStatus: s.status,\r",
                  "            category: s.cat,\r",
                  "            expectedField: s.field,\r",
                  "            type: s.type\r",
                  "        }, err, res)\r",
                  "    })\r",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {
              "content-type": true
            }
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Generated from cURL: curl -X POST https://dummyjson.com/auth/login \\\r\n     -H \"Content-Type: application/json\" \\\r\n     -d '{\r\n       \"username\": \"emilys\",\r\n       \"password\": \"emilyspass\",\r\n       \"expiresInMins\": 30\r\n     }'"
          },
          "response": []
        }
      ]
    }
  ]
}